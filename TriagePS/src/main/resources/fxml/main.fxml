<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unibo.controller.MainController"
      styleClass="root-pane"
      spacing="24" prefWidth="420" prefHeight="320" alignment="CENTER">

    <Label text="Gestione Pronto Soccorso" styleClass="title-label"/>
    <Label text="Inserisci il codice fiscale del paziente" styleClass="subtitle-label"/>

    <TextField fx:id="cfField"
               promptText="Codice Fiscale..."
               styleClass="cf-field"
               maxWidth="320"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="CERCA PAZIENTE" onAction="#onConferma" styleClass="btn-primary" prefWidth="180"/>
        <Button text="REGISTRA NUOVO" onAction="#onRegistra" styleClass="btn-secondary" prefWidth="150"/>
    </HBox>

    <Button text="Torna alla Dashboard" onAction="#onIndietro" styleClass="btn-secondary"/>

</VBox>
